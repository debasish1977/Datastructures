LeetCode 3: Longest Substring Without Repeating Characters?
//Clarifying Questions
//Can the String be empty or null?
//Should I return only the length, not the substring itself?
//Can the String contains only ASCII characters or fully unicode?

// Approach:
// I will use a sliding window with two pointers.
// The window [left...right] will always contain unique characters.
// I will store the latest index of each character in a HashMap.
// As I move right forward, if the current character was seen inside the current window,
// I will move left to one position after its previous index.
// After each step, I update the maximum window length.

//Time Complexity: O(N)
//Space Complexity: O(min(n, character_set_size))

class Solution {
    public int lengthOfLongestSubstring(String s) {
       if(s==null || s.length()==0)return 0;
       HashMap<Character,Integer> map = new HashMap<Character,Integer>();
       int left = 0;
       int maxLen = 0;
       for(int right=0;right<s.length();right++){
         char ch = s.charAt(right);
         if(map.containsKey(ch)){
            left = Math.max(left,map.get(ch)+1);
         }
         map.put(ch,right);
         maxLen = Math.max(maxLen,right - left + 1);
       }
       return maxLen;
    }
}


        
