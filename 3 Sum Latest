Leetcode 15 - 3 Sum
-----------------------
//Clarifying questions
//Input array contains both +ve and -ve integers?
//No Duplicate triplets?
//Input array can be empty? If yes, what should I return

//Approach
//I will solve this by two pointers approach
//After sorting, I fix one number nums[i], then use two pointers to find pairs that sum to -nums[i]. 
//I skip duplicate i values and duplicate left/right values after finding a valid triplet.

//Time Complexity: O(N^2)
//Space Complexity: O(1) excluding output, O(logN) possible due to sorting internals

class Solution {
    public List<List<Integer>> threeSum(int[] nums){
        List<List<Integer>> result = new ArrayList<>();
        if(nums==null || nums.length < 3)return result;
        Arrays.sort(nums);
        int sum = 0;
        for(int i=0;i<nums.length - 2;i++){
            if(i > 0 && nums[i]==nums[i-1])continue;
            int left = i+1;
            int right = nums.length - 1;
            while(left < right){
                sum = nums[i] + nums[left] + nums[right];
                if(sum == 0){
                    result.add(Arrays.asList(nums[i],nums[left],nums[right]));
                    while(left < right && nums[left] == nums[left+1])left++;
                    while(left < right && nums[right] == nums[right-1])right--;
                    left++;
                    right--;
                }
                else if(sum < 0) {
                    left++;
                }
                else {
                    right--;
                }
            }
        }
        return result;

    }
 }
