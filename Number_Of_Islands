Leetcode 200 -- Number Of Islands
//Clarifying Questions
//The grid contains only '1's & '0's?
//Island is formed by connecting adjacent lands horizontally or vertically? and not diagonally?
//Grid can be empty?

//Aproach
//I will do this using Flood Fill DFS
//I'll iterate through every cell in the grid. Whenever I encounter an unvisited land cell ('1'), I've discovered a new island, 
//so I'll increment the island count. Then I'll perform a DFS to visit every land cell connected to it and mark them as visited by 
//changing them to '0'. This ensures that each island is counted exactly once.

//Time Complexity: O(m*n)
//Space Complexity: O(m*n)


class Solution {
    public int numIslands(char[][] grid) {
        if(grid==null || grid.length==0)return 0;
        int rows = grid.length;
        int cols = grid[0].length;
        int numofIslands = 0;
        for(int i=0;i<rows;i++){
            for(int j=0;j<cols;j++){
                if(grid[i][j]=='1'){
                    numofIslands++;
                    dfs(grid,i,j);
                }
            }
        }
        return numofIslands;
    }

    //Helper method to perform DFS
    private void dfs(char[][] grid,int row,int col){
        int rows = grid.length;
        int cols = grid[0].length;
        if(row < 0 || col < 0 || row >= rows || col >= cols || grid[row][col]=='0')
        {
            return;
        }
        grid[row][col]='0';
        dfs(grid,row+1,col);
        dfs(grid,row-1,col);
        dfs(grid,row,col+1);
        dfs(grid,row,col-1);
    }
      
       
}
